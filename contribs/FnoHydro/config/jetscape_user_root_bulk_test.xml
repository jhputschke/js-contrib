<?xml version="1.0" ?>
<jetscape>

  <enableAutomaticTaskListDetermination
    > false </enableAutomaticTaskListDetermination>

  <nEvents> 1 </nEvents>

  <Random>
    <seed>1</seed>
  </Random>

  <vlevel> 0 </vlevel>

  <setReuseHydro> false </setReuseHydro>
  <nReuseHydro> 0 </nReuseHydro>

  <outputFilename>test2.dat</outputFilename>
  <JetScapeWriterAscii> on </JetScapeWriterAscii>

  <write_pthat> 1 </write_pthat>

  <!-- Inital State Module  -->
  <IS>
      <grid_max_x> 15 </grid_max_x>
      <grid_max_y> 15 </grid_max_y>
      <grid_max_z> 0 </grid_max_z>
      <grid_step_x> 0.2 </grid_step_x>
      <grid_step_y> 0.2 </grid_step_y>

      <Trento>
        <PhysicsInputs
                projectile='Au'
                target='Au'
                sqrts='200'
                cross-section='4.2'
                normalization='5.73'
            >
        </PhysicsInputs>
        <CutInputs centrality-low='0' centrality-high='10'>
        </CutInputs>
        <TransInputs
                reduced-thickness='0.063'
                fluctuation="1.05"
                nucleon-width="1.12"
                nucleon-min-dist="1.4"
            >
        </TransInputs>
        <LongiInputs
                mean-coeff="1.0"
                std-coeff="3.0"
                skew-coeff="0.0"
                skew-type="1"
                jacobian="0.8"
            >
        </LongiInputs>
      </Trento>
  </IS>

  <!-- Hard Process  -->
  <Hard>
    <PGun>
        <name>PGun</name>
        <pT>20</pT>
        <parID>21</parID>
    </PGun>

     <PythiaGun>
       <pTHatMin>20</pTHatMin>
       <pTHatMax>21</pTHatMax>
       <eCM>200</eCM>
     </PythiaGun>
   </Hard>

   <!-- Parton Gun test with fixed pT and fixed IS pos = 0  -->
   <!-- <Hard>
    <PGun>
        <name>PGun</name>
        <pT>20</pT>
        <parID>21</parID>
    </PGun>
   </Hard> -->

  <!--Preequilibrium Dynamics Module -->
  <Preequilibrium>
      <tau0>0.5</tau0>
      <NullPreDynamics> </NullPreDynamics>
  </Preequilibrium>

  <!-- Hydro  Module  -->
  <Hydro>
      <MUSIC>
          <beastMode>1</beastMode>
          <output_evolution_to_file>0</output_evolution_to_file>
          <!--  <output_evolution_every_N_timesteps>10</output_evolution_every_N_timesteps> -->
          <output_evolution_to_memory>1</output_evolution_to_memory>
          <surface_in_memory>1</surface_in_memory>
          <Initial_time_tau_0>0.5</Initial_time_tau_0>
          <shear_viscosity_eta_over_s>0</shear_viscosity_eta_over_s>

          <!--> REMARK: Make sure to use ideal hydro, otherwise soft hadronization needs additional information in FNO etc !!!!
          Include_Shear_Visc_Yes_1_No_0 0    # include shear viscous effect
          Include_Bulk_Visc_Yes_1_No_0 0     # include bulk viscous effect
          Include_second_order_terms 0       # include second order non-linear coupling terms
          -->

          <!--
          <T_dependent_Shear_to_S_ratio>3</T_dependent_Shear_to_S_ratio>
          <eta_over_s_T_kink_in_GeV>0.223</eta_over_s_T_kink_in_GeV>
          <eta_over_s_low_T_slope_in_GeV>-0.776</eta_over_s_low_T_slope_in_GeV>
          <eta_over_s_high_T_slope_in_GeV>0.37</eta_over_s_high_T_slope_in_GeV>
          <eta_over_s_at_kink>0.096</eta_over_s_at_kink>
          <temperature_dependent_bulk_viscosity>3</temperature_dependent_bulk_viscosity>
          <zeta_over_s_max>0.133</zeta_over_s_max>
          <zeta_over_s_T_peak_in_GeV>0.12</zeta_over_s_T_peak_in_GeV>
          <zeta_over_s_width_in_GeV>0.072</zeta_over_s_width_in_GeV>
          <zeta_over_s_lambda_asymm>-0.122</zeta_over_s_lambda_asymm>
          -->

          <freezeout_temperature>0.136</freezeout_temperature>
      </MUSIC>

      <FNO>
        <model_file
            >../fno_hydro/models/traced_JS3.7_1k_3feat_fno_model_cpu_49bins.pt</model_file>

        <!-- Not really used yet ...  !!! -->
        <centrality-low>0</centrality-low>
        <centrality-high>10</centrality-high>
        <EOS_id_MUSIC>91</EOS_id_MUSIC>
         <!--Trained on model/hydro grid parameters, explore super resolution later !!! -->
        <n_features>3</n_features>
        <freezeout_temperature>0.136</freezeout_temperature>
        <nx>60</nx>
        <ny>60</ny>
        <neta>1</neta>
        <ntau>49</ntau>
        <x_min>-15.0</x_min>
        <y_min>-15.0</y_min>
         <!-- <dx>0.5</dx>
        <dy>0.5</dy> -->
        <dtau>0.1</dtau>
        <deta>0</deta>

      </FNO>

      <FNOROOIN>
        <model_file
            >../fno_hydro/models/traced_JS3.7_10k_3feat_fno_model_cpu_40_60_59bins.pt</model_file>
        <!-- <model_file traced_JS3.7_1k_3feat_fno_model_cpu_49bins.pt
            >../fno_hydro/models/traced_JS3.7.fno_model_cpu.pt</model_file> -->
        <root_file
            > /Users/du8478/FNO_Hydro_Data/cent_40_60_10K_events.root </root_file>
        <!-- <root_file full_cent_0_10_1kev.root</root_file> cent_40_60_10K_events.root
            >/Users/du8478/FNO_Hydro_Data/AuAu_0_10_ideal_JS_3.7_user_res/bulk_root_writer_JS_3.7_AuAu_0_10_250ev.root</root_file> -->
        <!-- <root_file>bulk_root_writer_full_test_5ev.root</root_file> -->

        <fullHydroIn> 0 </fullHydroIn>
        <bulkHadroFull> 1 </bulkHadroFull>
        <QAoutput> 1 </QAoutput>

        <!-- Not really used yet ...  !!! -->
        <centrality-low>0</centrality-low>
        <centrality-high>10</centrality-high>
        <EOS_id_MUSIC>91</EOS_id_MUSIC>
         <!--Trained on model/hydro grid parameters, explore super resolution later !!! -->
        <n_features>3</n_features>
        <tau0>0.5</tau0>
        <freezeout_temperature>0.136</freezeout_temperature>
        <nx>60</nx>
        <ny>60</ny>
        <neta>1</neta>
        <ntau>59</ntau>
        <x_min>-15.0</x_min>
        <y_min>-15.0</y_min>
         <!-- <dx>0.5</dx>
        <dy>0.5</dy> -->
        <dtau>0.1</dtau>
        <deta>0</deta>

      </FNOROOIN>

  </Hydro>

  <SoftParticlization>
     <iSS>
         <!-- file path for the default input file  -->
         <iSS_input_file>iSS_parameters.dat</iSS_input_file>
         <!-- directory path where the hydro surface is stored  -->
         <iSS_table_path>iSS_tables</iSS_table_path>
         <!-- file path for the default particle table files  -->
         <iSS_particle_table_path>iSS_tables</iSS_particle_table_path>
         <afterburner_type>2</afterburner_type>
         <number_of_repeated_sampling>1</number_of_repeated_sampling>
         <include_deltaf_shear>0</include_deltaf_shear>
         <include_deltaf_bulk>0</include_deltaf_bulk>
         <Perform_resonance_decays>0</Perform_resonance_decays>
     </iSS>
   </SoftParticlization>

  <!--Eloss Modules -->
    <Eloss>
        <maxT>100</maxT>
      <Matter>
          <!-- if not using lbt, use Q0=1; if using lbt use 2 -->
        <Q0> 2.0 </Q0>
        <in_vac> 0 </in_vac>
        <vir_factor> 0.25 </vir_factor>
        <recoil_on> 1 </recoil_on>
        <broadening_on> 0 </broadening_on>
        <!-- <brick_med> 1 </brick_med> -->
        <!-- <!-1- maybe 4. is too long, but we can try 1 -> 2 -> 3 -> 5 etc... to see the change -->
        <!-- based on the modification, using the same density--> -->
        <!-- <brick_length> 14 </brick_length> -->
        <hydro_Tc> 0.16 </hydro_Tc>
      </Matter>

      <!-- can run SMASH if I want, but not needed because we are using a separate backgound,
      but when it's used, then it needs to run SMASH separately after JETSCAPE, can add later if wanted for correct background-->

      <Lbt>
        <name> Lbt </name>
        <Q0> 2.0 </Q0>
        <in_vac> 0 </in_vac>
        <only_leading> 0 </only_leading>
        <hydro_Tc> 0.16 </hydro_Tc>
        <alphas> 0.2 </alphas>
        <run_alphas>1</run_alphas>
      </Lbt>

    </Eloss>

    <!-- Jet Hadronization Module -->
    <JetHadronization>
      <name>colorless</name>
    </JetHadronization>

</jetscape>
