# Dockerfile.dev.blackwell — X-SCAPE + music4gpu + js-contrib + FNO4d development image
#
# Target:  Blackwell generation (CUDA 13.2, sm_75–sm_100)
#          GB200, GB10 (sm_100) in addition to RTX 20/30/40xx, A100, H100, GH200
#
# Build (multi-arch):
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -t xscape-fno4d-dev:cu132 -f Dockerfile.dev.blackwell .
#
# Build (local arch only):
#   docker build -t xscape-fno4d-dev:cu132 -f Dockerfile.dev.blackwell .
#
# This image contains only build/runtime dependencies.
# Source trees are mounted at runtime; the user performs configure/build/install.
# See PlanContainerDev.md for the full user workflow.
#
# Differences from Dockerfile.dev:
#   Phase 1 FROM:  nvidia/cuda:13.2.1-devel-ubuntu24.04  (CUDA 13.2 nvcc, sm_100 support)
#   Phase 3 PyTorch: cu132 wheel (native CUDA 13.2; no backward-compat layer needed)
#   cmake -DCMAKE_CUDA_ARCHITECTURES should include 100 for Blackwell targets.

# ── Phase 1: Base layer ────────────────────────────────────────────────────
FROM nvidia/cuda:13.2.1-devel-ubuntu24.04

ARG DEBIAN_FRONTEND=noninteractive
ARG TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends \
    git wget curl ca-certificates ninja-build pkg-config \
    libx11-dev libxft-dev libxext-dev libxpm-dev libssl-dev \
  && rm -rf /var/lib/apt/lists/*

# Notes:
# - build-essential (GCC 13, g++, make) and nvcc are already in the devel base.
# - X11 dev headers required by ROOT even in headless/batch mode.
# - cmake, boost, hdf5, gsl, pythia8 come from conda-forge (consistent ABI).

# ── Phase 2: miniforge3 + conda environment ───────────────────────────────
RUN ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "aarch64" || echo "x86_64") \
  && wget -q "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-${ARCH}.sh" \
       -O /tmp/miniforge.sh \
  && bash /tmp/miniforge.sh -b -p /opt/miniforge3 \
  && rm /tmp/miniforge.sh \
  && /opt/miniforge3/bin/conda config --set auto_activate_base false

RUN /opt/miniforge3/bin/mamba create -n xscape python=3.11 -y -c conda-forge

# conda owns ONLY the C++/HEP/ABI layer + python + numpy. Every pure-Python leaf
# package (scientific/viz/cloud/ML) is installed via pip in Phase 3 — pip's
# resolver + precompiled wheels sidestep the conda SAT backtracking that the heavy
# metapackages (Qt via matplotlib, protobuf via wandb/google-cloud) trigger.
# The conda steps stay split so ROOT's large tree solves in isolation.

# Step 1: build tools + C++ build/runtime libs (+ pybind11 for find_package)
RUN /opt/miniforge3/bin/mamba install -n xscape -y -c conda-forge \
    cmake make compilers "pybind11>=2.11" \
    boost-cpp zlib hdf5 gsl openmpi \
  && /opt/miniforge3/bin/mamba clean -afy

# Step 2: HEP packages (boost/hdf5/gsl already pinned — smaller solve)
RUN /opt/miniforge3/bin/mamba install -n xscape -y -c conda-forge \
    pythia8 hepmc3 fastjet \
  && /opt/miniforge3/bin/mamba clean -afy

# Step 3: ROOT alone (large tree; isolated solve avoids combined OOM).
# Use root_base, not the full 'root' metapackage. root_base IS the complete ROOT
# build (Core/RIO/Tree/Hist/Graf/Gpad/PyROOT) and ships ROOTConfig.cmake for
# find_package(ROOT) — it covers everything X-SCAPE uses (TFile, TTree, TH1/2/3,
# TF1, TCanvas, TString, TSystem, TRandom, TMath). The full 'root' only adds
# notebook/metakernel/ipython/numba/compilers — none needed here (compilers +
# jupyterlab are installed separately; numba is unused) — and its numba->llvmlite
# LLVM pin fights ROOT's cling LLVM, bloating the solve.
# Pin numpy>=2.0: this is the single numpy for the whole env (ROOT/PyROOT link it,
# and the pip layer in Phase 3 is constrained to it), so fix the floor here.
RUN /opt/miniforge3/bin/mamba install -n xscape -y -c conda-forge \
    root_base "numpy>=2.0" \
  && /opt/miniforge3/bin/mamba clean -afy

# Notes:
# - 'compilers' installs the arch-specific conda cross-compiler (CXX) for
#   C++ TUs; ensures ABI compatibility with conda-forge Pythia8/ROOT/HDF5.
# - nvcc uses CUDAHOSTCXX=/usr/bin/g++ (system GCC 13) — set in Phase 4.

# ── Phase 3: pip layer — PyTorch + ALL pure-Python packages ───────────────
# conda above owns only the C++/HEP/ABI layer + python + numpy. Everything that
# does not link the conda C++ stack is installed here: pip's resolver and
# precompiled wheels avoid the conda SAT backtracking that the ML/viz/cloud
# metapackages (Qt via matplotlib, protobuf via wandb/google-cloud) trigger.
#
# numpy is left unconstrained: pip may upgrade the conda-installed numpy to suit
# the leaf wheels. That can break PyROOT's bindings, but the C++ ROOT libraries
# (libRIO/libTree, used by the X-SCAPE build) don't depend on Python numpy, and
# PyROOT is unused here — so this is intentionally acceptable.

# PyTorch (CUDA 13.2) from the dedicated index (numpy already present from conda).
RUN /opt/miniforge3/envs/xscape/bin/pip install \
    torch torchvision \
    --index-url https://download.pytorch.org/whl/cu132 \
  && /opt/miniforge3/envs/xscape/bin/pip cache purge

# Scientific / viz / cloud / FNO4d stack from PyPI in one resolution.
# matplotlib here is the pip wheel (Agg backend, no Qt). h5py's wheel bundles its
# own HDF5 — independent of the conda hdf5 the C++ build links, which is fine for
# Python-side I/O (the HDF5 file format is stable across the two).
RUN /opt/miniforge3/envs/xscape/bin/pip install \
    matplotlib scipy h5py zarr uproot awkward \
    opt-einsum tensorly scikit-image psutil seaborn tqdm \
    "ruamel.yaml" wandb \
# gcsfs google-cloud-storage   <- disabled for now; pelicanfs (below) is the planned production data layer
    jupyterlab ipykernel \
    tensorly-torch "zencfg>=0.3.0" configmypy pelicanfs \
  && /opt/miniforge3/envs/xscape/bin/pip cache purge

# Notes:
# - PyTorch 2.12+ ships native cu132 wheels; no CUDA backward-compat layer needed.
# - neuraloperator is NOT installed here; FNO4d vendors its own pinned fork
#   (neuraloperator-4d-2.0.0) installed as an editable install at runtime.
# - libtorch for FnoHydro cmake find_package(Torch) is provided by the torch
#   wheel above. Locate at configure time with:
#     python -c "import torch; print(torch.utils.cmake_prefix_path)"

# ── Phase 4: Environment variables ────────────────────────────────────────
ENV CONDA_ENV=/opt/miniforge3/envs/xscape \
    PATH=/opt/miniforge3/envs/xscape/bin:/opt/miniforge3/bin:$PATH \
    PYTHIA8=/opt/miniforge3/envs/xscape \
    PYTHIA8DIR=/opt/miniforge3/envs/xscape \
    ROOTSYS=/opt/miniforge3/envs/xscape \
    CMAKE_PREFIX_PATH=/opt/miniforge3/envs/xscape \
    CUDAHOSTCXX=/usr/bin/g++ \
    LD_LIBRARY_PATH=/opt/miniforge3/envs/xscape/lib:$LD_LIBRARY_PATH

WORKDIR /workspace
EXPOSE 8888
CMD ["bash"]
